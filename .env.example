# ── Optional: default live data source ───────────────────────────────────────
# Paste a Google Sheet share link (Share → Anyone with the link → Viewer) or any
# public CSV URL. When set, the deployed dashboard auto-connects on load and
# polls it (~10s), so editing the sheet updates the demo for every visitor.
# Set in Vercel: Project → Settings → Environment Variables.
NEXT_PUBLIC_LIVE_SOURCE_URL=

# ── Optional: server-side persistent KPI history (shared across devices) ──────
# Without these, history is stored per-browser in localStorage. To make the
# History tab a shared, cross-device record, create a Vercel KV / Upstash Redis
# store (Vercel → Storage → KV) and add its REST credentials here. The app reads
# them automatically and switches the History tab to server storage.
KV_REST_API_URL=
KV_REST_API_TOKEN=
