# Optional: a default live data source for the demo.
# Paste a Google Sheet share link (Share → Anyone with the link → Viewer) or any
# public CSV URL. When set, the deployed dashboard auto-connects on load and
# polls it (~10s), so editing the sheet updates the demo for every visitor.
#
# Set this in Vercel: Project → Settings → Environment Variables.
NEXT_PUBLIC_LIVE_SOURCE_URL=
